{
  "manifest_version": 3,
  "name": "Meta & Open Graph Tester",
  "version": "0.1.0",
  "description": "Inspect meta, Open Graph, and Twitter Card tags on the current page, with link previews and validation.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meta & OG Tester",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
